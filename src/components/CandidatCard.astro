---
import type { CandidatIndex } from '@/lib/data';

export interface Props {
    candidat: CandidatIndex;
}
const { candidat: c } = Astro.props;

const initiales = c.nom_complet
    .replace(/^M\.\s*|^Mme\s*/, '')
    .split(/\s+/)
    .map((m) => m[0])
    .slice(0, 2)
    .join('')
    .toUpperCase();

const couleur = c.couleur_hex ?? '#64748b';
const statutLabel: Record<string, string> = {
    declare: 'Déclaré', pressenti: 'Pressenti', investi: 'Investi',
    parrainages_valides: '500 parrainages validés', retire: 'Retiré', elimine_t1: 'Éliminé T1',
};
---

<article class="rounded-card border p-4 flex flex-col gap-3" style="border-color: var(--border)">
    <div class="flex items-center gap-3">
        <span
            class="grid place-items-center rounded-full text-white font-semibold shrink-0"
            style={`background:${couleur}; width:48px; height:48px`}
            aria-hidden="true">{initiales}</span>
        <div class="min-w-0">
            <h3 class="font-semibold leading-tight truncate">{c.nom_complet.replace(/^M\.\s*|^Mme\s*/, '')}</h3>
            <p class="text-sm truncate" style="color: var(--fg-muted)">{c.parti_soutien}</p>
        </div>
    </div>

    <div class="flex flex-wrap gap-2 text-xs">
        <span class="px-2 py-1 rounded-control" style="background: color-mix(in srgb, var(--etat-publie, #059669) 12%, transparent); color: #047857">
            {statutLabel[c.statut_candidature] ?? c.statut_candidature}
        </span>
        <span class="px-2 py-1 rounded-control" style="background: var(--bg-soft); color: var(--fg-muted)">
            S'est exprimé sur {c.couverture.themes_exprimes} / {c.couverture.themes_total} thèmes
        </span>
    </div>

    <a
        href={`/candidats/${c.slug}/`}
        class="tap mt-auto inline-flex items-center justify-center rounded-control bg-brand-600 text-white text-sm font-medium px-4 py-2 hover:bg-brand-800">
        Voir la fiche
    </a>
</article>
