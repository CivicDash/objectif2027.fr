---
import Base from '@/layouts/Base.astro';
import { CANDIDATS_DETAIL, THEMES, META, badgeParrainages, type EtatTheme } from '@/lib/data';

export function getStaticPaths() {
    return Object.values(CANDIDATS_DETAIL).map((c: any) => ({ params: { slug: c.slug }, props: { candidat: c } }));
}

const { candidat: c } = Astro.props;
const couleur = c.couleur_hex ?? '#64748b';
const nom = c.nom_complet.replace(/^M\.\s*|^Mme\s*/, '');
const parrainages = badgeParrainages(c.statut_candidature);

const prisesDeParole = c.prises_de_parole ?? [];
const ancres = [
    { id: 'programme', label: 'Programme' },
    ...(prisesDeParole.length ? [{ id: 'prises-de-parole', label: 'Prises de parole' }] : []),
    { id: 'parcours', label: 'Parcours' },
    { id: 'affaires', label: 'Affaires' },
];

function etatDe(slug: string): EtatTheme {
    return (c.etats_par_theme?.[slug]?.etat ?? 'non_exprime') as EtatTheme;
}
---

<Base title={`${nom} — programme et parcours | Objectif 2027`} description={`${nom} (${c.parti_soutien ?? ''}) : programme thème par thème, parcours, affaires judiciaires — sourcé et neutre.`} ogImage={`/og/${c.slug}.png`}>
    <nav aria-label="Fil d'Ariane" class="text-sm pt-2" style="color: var(--fg-muted)">
        <a href="/" class="text-brand-600 hover:underline">Accueil</a> ·
        <a href="/candidats/" class="text-brand-600 hover:underline">Candidats</a> · {nom}
    </nav>

    <!-- Hero : bannière image si dispo, sinon dégradé de la couleur du candidat -->
    <div class="relative -mx-4 mt-2 h-28 md:h-40 bg-cover bg-center"
         style={c.hero_banner?.url
            ? `background-image: linear-gradient(90deg, rgba(0,0,0,.25), transparent), url('${c.hero_banner.url}'); background-color:${couleur}`
            : `background: linear-gradient(135deg, ${couleur} 0%, color-mix(in srgb, ${couleur} 12%, transparent) 100%)`}>
        {(c.hero_banner?.credit || c.photo?.credit) && (
            <span class="absolute bottom-1 right-2 text-[10px] px-1 rounded" style="background: rgba(0,0,0,.45); color:#fff">
                © {c.hero_banner?.credit ?? c.photo?.credit} · {c.hero_banner?.licence ?? c.photo?.licence}
            </span>
        )}
    </div>
    <header class="-mt-10 flex items-end gap-4">
        {c.photo?.url ? (
            <img src={c.photo.url} alt={`Portrait de ${nom}`} width="80" height="80"
                 class="rounded-full object-cover shrink-0 border-4" style="width:80px;height:80px;border-color:var(--bg)" />
        ) : (
            <span class="grid place-items-center rounded-full text-white text-xl font-bold shrink-0 border-4"
                  style={`background:${couleur}; width:80px; height:80px; border-color:var(--bg)`} aria-hidden="true">
                {nom.split(/\s+/).map((m: string) => m[0]).slice(0, 2).join('')}
            </span>
        )}
        <div class="pb-1">
            <h1 class="text-2xl font-extrabold leading-tight">{nom}</h1>
            <p style="color: var(--fg-muted)">{c.parti_soutien}</p>
            {c.slogan && <p class="italic mt-0.5" style="color: var(--fg-muted)">« {c.slogan} »</p>}
            <div class="mt-2 flex flex-wrap gap-2 text-xs">
                <span class="px-2 py-1 rounded-control text-white" style={`background:${couleur}`}>{c.nuance}</span>
                <span class="px-2 py-1 rounded-control" style={parrainages.ton === 'vert' ? 'background:#ecfdf5;color:#047857' : 'background:#fffbeb;color:#b45309'}>{parrainages.texte}</span>
                <span class="px-2 py-1 rounded-control" style="background: var(--bg-soft)">
                    Exprimé sur {c.couverture.themes_exprimes} / {c.couverture.themes_total} thèmes
                </span>
                {c.site_campagne_url && (
                    <a href={c.site_campagne_url} rel="nofollow noopener" class="px-2 py-1 rounded-control text-brand-600 hover:underline">Site de campagne ↗</a>
                )}
            </div>
        </div>
    </header>

    <!-- Barre d'ancres sticky -->
    <nav aria-label="Sections de la fiche" class="sticky top-0 z-10 -mx-4 px-4 py-2 border-b flex gap-4 text-sm overflow-x-auto"
         style="background: var(--bg); border-color: var(--border)">
        {ancres.map((a) => <a href={`#${a.id}`} class="tap inline-flex items-center whitespace-nowrap hover:text-brand-600">{a.label}</a>)}
    </nav>

    <!-- Programme par thème (3 états honnêtes) -->
    <section id="programme" class="py-6">
        <h2 class="text-xl font-bold mb-3">Programme</h2>
        <div class="space-y-3">
            {THEMES.map((t) => {
                const etat = etatDe(t.slug);
                const info = c.etats_par_theme?.[t.slug] ?? {};
                const mesures = c.mesures_par_theme?.[t.slug] ?? [];
                return (
                    <div class="rounded-card border p-4" style="border-color: var(--border)">
                        <div class="flex items-center justify-between gap-3">
                            <h3 class="font-semibold">{t.nom}</h3>
                            <span class="text-xs px-2 py-1 rounded-full whitespace-nowrap"
                                  style={etat === 'publie' ? 'background:#ecfdf5;color:#047857'
                                       : etat === 'en_traitement' ? 'background:#fffbeb;color:#b45309'
                                       : 'background:var(--bg-soft);color:var(--fg-muted)'}>
                                {etat === 'publie' ? `${info.nb_mesures} mesure(s)`
                                 : etat === 'en_traitement' ? 'En cours de traitement'
                                 : 'Non exprimé'}
                            </span>
                        </div>
                        {etat === 'publie' && (
                            <ul class="mt-3 space-y-2">
                                {mesures.map((m: any) => (
                                    <li class="text-sm">
                                        <span class="font-medium">{m.titre}</span>
                                        {m.source_url && <a href={m.source_url} rel="nofollow noopener" class="text-brand-600 hover:underline ml-1">source ↗</a>}
                                    </li>
                                ))}
                            </ul>
                        )}
                        {etat === 'en_traitement' && (
                            <p class="mt-2 text-sm" style="color: var(--fg-muted)">
                                S'est exprimé sur ce thème ({info.nb_signaux} prise(s) de parole repérée(s)) — en cours de
                                vérification par notre équipe avant publication.
                                {info.source_url && <a href={info.source_url} rel="nofollow noopener" class="text-brand-600 hover:underline ml-1">source ↗</a>}
                            </p>
                        )}
                        {etat === 'non_exprime' && (
                            <p class="mt-2 text-sm" style="color: var(--fg-muted)">Ne s'est pas exprimé sur ce thème à ce jour.</p>
                        )}
                    </div>
                );
            })}
        </div>
    </section>

    <!-- Prises de parole : citations vérifiables à la source (différenciateur) -->
    {prisesDeParole.length > 0 && (
        <section id="prises-de-parole" class="py-6">
            <h2 class="text-xl font-bold mb-1">Prises de parole</h2>
            <p class="text-sm mb-4" style="color: var(--fg-muted)">
                Propos repérés dans les meetings et interviews, en cours de traitement par notre équipe.
                <strong>Chaque citation est vérifiable à la source en un clic.</strong>
            </p>
            <div class="space-y-4">
                {prisesDeParole.map((doc: any) => (
                    <div class="rounded-card border p-4" style="border-color: var(--border)">
                        <div class="flex items-center justify-between gap-2 mb-2">
                            <h3 class="font-semibold text-sm">
                                {doc.url ? <a href={doc.url} rel="nofollow noopener" class="hover:text-brand-600">{doc.titre} ↗</a> : doc.titre}
                            </h3>
                            <span class="text-xs whitespace-nowrap" style="color: var(--fg-muted)">{doc.type}{doc.date ? ` · ${doc.date}` : ''}</span>
                        </div>
                        <ul class="space-y-3">
                            {doc.citations.map((cit: any) => (
                                <li class="text-sm border-l-2 pl-3" style="border-color: var(--border)">
                                    <p class="italic">« {cit.citation} »</p>
                                    {cit.resume && <p class="text-xs mt-1" style="color: var(--fg-muted)">{cit.resume}</p>}
                                    {cit.verifier_url && (
                                        <a href={cit.verifier_url} rel="nofollow noopener"
                                           class="tap inline-flex items-center mt-1 text-xs font-medium text-brand-600 hover:underline">
                                            ▶ Vérifier{cit.timecode ? ` à ${cit.timecode}` : ' à la source'}
                                        </a>
                                    )}
                                </li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
        </section>
    )}

    <!-- Parcours -->
    <section id="parcours" class="py-6">
        <h2 class="text-xl font-bold mb-3">Parcours</h2>
        {c.parcours?.length ? (
            <ol class="border-l-2 pl-4 space-y-4" style="border-color: var(--border)">
                {c.parcours.map((e: any) => (
                    <li>
                        <div class="text-sm font-medium">{e.titre}{e.organisation && <span style="color: var(--fg-muted)"> · {e.organisation}</span>}</div>
                        <div class="text-xs" style="color: var(--fg-muted)">
                            {e.date_debut ?? '?'}{e.date_fin ? ` — ${e.date_fin}` : ' — en cours'}
                            {e.source_url && <a href={e.source_url} rel="nofollow noopener" class="text-brand-600 hover:underline ml-1">source ↗</a>}
                        </div>
                    </li>
                ))}
            </ol>
        ) : (
            <p class="text-sm" style="color: var(--fg-muted)">Parcours en cours de constitution (import Wikidata / HATVP).</p>
        )}
    </section>

    <!-- Affaires judiciaires : état vide daté (présomption d'innocence par défaut) -->
    <section id="affaires" class="py-6">
        <h2 class="text-xl font-bold mb-3">Affaires judiciaires</h2>
        <div class="rounded-card border p-4 text-sm" style="border-color: var(--border); color: var(--fg-muted)">
            Aucune affaire judiciaire recensée à ce jour dans notre base — dernière vérification : {META.genere_le}.
            Une absence d'information n'est pas une preuve d'absence d'affaire ; toute information éventuelle serait
            sourcée et modérée humainement, avec présomption d'innocence.
        </div>
    </section>

    <div class="py-4 flex flex-wrap gap-3">
        <a href="/comparateur/" class="tap inline-flex items-center rounded-control bg-brand-600 text-white text-sm font-medium px-4 py-2 hover:bg-brand-800">Comparer</a>
        <a href="/candidats/" class="tap inline-flex items-center rounded-control border text-sm px-4 py-2" style="border-color: var(--border)">← Tous les candidats</a>
    </div>
</Base>
