---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import AnchorNav from '@/components/AnchorNav.astro';
import { CANDIDATS_DETAIL, THEMES, META, badgeParrainages, type EtatTheme } from '@/lib/data';

export function getStaticPaths() {
    return Object.values(CANDIDATS_DETAIL).map((c: any) => ({ params: { slug: c.slug }, props: { candidat: c } }));
}

const { candidat: c } = Astro.props;
const couleur = c.couleur_hex ?? '#64748b';
const nom = c.nom_complet.replace(/^M\.\s*|^Mme\s*/, '');
const parrainages = badgeParrainages(c.statut_candidature);

const prisesDeParole = c.prises_de_parole ?? [];

// Regroupement du programme : publiés, puis relevés, puis en traitement, non-exprimés repliés.
const themesPublies = THEMES.filter((t) => etatDe(t.slug) === 'publie');
const themesReleves = THEMES.filter((t) => etatDe(t.slug) === 'relevee');
const themesTraitement = THEMES.filter((t) => etatDe(t.slug) === 'en_traitement');
const themesNonExprimes = THEMES.filter((t) => etatDe(t.slug) === 'non_exprime');

// Libellé de thème pour les citations des prises de parole.
const nomTheme = (slug: string | null) => THEMES.find((t) => t.slug === slug)?.nom ?? 'Autre';

// Citations groupées par thème dans chaque document (dropdown par rubrique).
function citationsParTheme(doc: any): [string, any[]][] {
    const groupes: Record<string, any[]> = {};
    for (const cit of doc.citations) (groupes[nomTheme(cit.theme)] ??= []).push(cit);
    return Object.entries(groupes).sort((a, b) => b[1].length - a[1].length);
}

const ancres = [
    { id: 'programme', label: 'Programme' },
    ...(prisesDeParole.length ? [{ id: 'prises-de-parole', label: 'Prises de parole' }] : []),
    { id: 'parcours', label: 'Parcours' },
    { id: 'affaires', label: 'Affaires' },
];

function etatDe(slug: string): EtatTheme {
    return (c.etats_par_theme?.[slug]?.etat ?? 'non_exprime') as EtatTheme;
}
---

<Base title={`${nom} — programme et parcours | Objectif 2027`} description={`${nom} (${c.parti_soutien ?? ''}) : programme thème par thème, parcours, affaires judiciaires — sourcé et neutre.`} ogImage={`/og/${c.slug}.png`}>
    <Breadcrumb items={[{ label: 'Candidats', href: '/candidats/' }, { label: nom }]} />

    <!-- Hero : bannière image si dispo, sinon dégradé de la couleur du candidat -->
    <div class="relative -mx-4 mt-2 h-28 md:h-40 bg-cover bg-center"
         style={c.hero_banner?.url
            ? `background-image: linear-gradient(90deg, rgba(0,0,0,.25), transparent), url('${c.hero_banner.url}'); background-color:${couleur}`
            : `background: linear-gradient(135deg, ${couleur} 0%, color-mix(in srgb, ${couleur} 12%, transparent) 100%)`}>
        {(c.hero_banner?.credit || c.photo?.credit) && (
            <span class="absolute bottom-1 right-2 text-[10px] px-1 rounded" style="background: rgba(0,0,0,.45); color:#fff">
                © {c.hero_banner?.credit ?? c.photo?.credit} · {c.hero_banner?.licence ?? c.photo?.licence}
            </span>
        )}
    </div>
    <header class="-mt-10 flex items-end gap-4">
        {c.photo?.url ? (
            <img src={c.photo.url} alt={`Portrait de ${nom}`} width="80" height="80"
                 class="rounded-full object-cover shrink-0 border-4" style="width:80px;height:80px;border-color:var(--bg)" />
        ) : (
            <span class="grid place-items-center rounded-full text-white text-xl font-bold shrink-0 border-4"
                  style={`background:${couleur}; width:80px; height:80px; border-color:var(--bg)`} aria-hidden="true">
                {nom.split(/\s+/).map((m: string) => m[0]).slice(0, 2).join('')}
            </span>
        )}
        <div class="pb-1">
            <h1 class="text-2xl font-extrabold leading-tight">{nom}</h1>
            <p style="color: var(--fg-muted)">{c.parti_soutien}</p>
            {c.slogan && <p class="italic mt-0.5" style="color: var(--fg-muted)">« {c.slogan} »</p>}
            <div class="mt-2 flex flex-wrap gap-2 text-xs">
                <span class="px-2 py-1 rounded-control text-white" style={`background:${couleur}`}>{c.nuance}</span>
                <span class="px-2 py-1 rounded-control" style={parrainages.ton === 'vert' ? 'background:#ecfdf5;color:#047857' : 'background:#fffbeb;color:#b45309'}>{parrainages.texte}</span>
                <span class="px-2 py-1 rounded-control" style="background: var(--bg-soft)">
                    Exprimé sur {c.couverture.themes_exprimes} / {c.couverture.themes_total} thèmes
                </span>
                {c.site_campagne_url && (
                    <a href={c.site_campagne_url} target="_blank" rel="nofollow noopener" class="px-2 py-1 rounded-control text-brand-600 hover:underline">Site de campagne ↗</a>
                )}
                {Object.entries(c.reseaux ?? {}).map(([res, url]) => (
                    <a href={url as string} target="_blank" rel="nofollow noopener" class="px-2 py-1 rounded-control border hover:border-brand-400" style="border-color: var(--border); color: var(--fg-muted)">
                        {{ site: 'Site', x: 'X', instagram: 'Instagram', facebook: 'Facebook', mastodon: 'Mastodon', bluesky: 'Bluesky', linkedin: 'LinkedIn', youtube: 'YouTube' }[res] ?? res} ↗
                    </a>
                ))}
            </div>
        </div>
    </header>

    <AnchorNav items={ancres} />

    <!-- Programme par thème (3 états honnêtes) — publiés d'abord, non-exprimés repliés -->
    <section id="programme" class="py-6">
        <h2 class="text-xl font-bold mb-3">Programme</h2>
        <div class="space-y-3">
            {[...themesPublies, ...themesReleves, ...themesTraitement].map((t) => {
                const etat = etatDe(t.slug);
                const info = c.etats_par_theme?.[t.slug] ?? {};
                const mesures = c.mesures_par_theme?.[t.slug] ?? [];
                const relevees = c.mesures_relevees_par_theme?.[t.slug] ?? [];
                return (
                    <div class="rounded-card border p-4" style="border-color: var(--border)">
                        <div class="flex items-center justify-between gap-3">
                            <h3 class="font-semibold">{t.nom}</h3>
                            <span class="text-xs px-2 py-1 rounded-full whitespace-nowrap"
                                  style={etat === 'publie' ? 'background:#ecfdf5;color:#047857'
                                       : etat === 'relevee' ? 'background:#eff6ff;color:#1d4ed8'
                                       : 'background:#fffbeb;color:#b45309'}>
                                {etat === 'publie' ? `${info.nb_mesures} mesure(s)`
                                 : etat === 'relevee' ? `${info.nb_mesures} mesure(s) relevée(s)`
                                 : 'En cours de traitement'}
                            </span>
                        </div>
                        {etat === 'publie' && (
                            <ul class="mt-3 space-y-2">
                                {mesures.map((m: any) => (
                                    <li class="text-sm">
                                        <span class="font-medium">{m.titre}</span>
                                        {m.source_url && <a href={m.source_url} target="_blank" rel="nofollow noopener" class="text-brand-600 hover:underline ml-1">source ↗</a>}
                                    </li>
                                ))}
                            </ul>
                        )}
                        {etat === 'relevee' && (
                            <>
                                <ul class="mt-3 space-y-2">
                                    {relevees.map((m: any) => (
                                        <li class="text-sm">
                                            <span class="font-medium">{m.titre}</span>
                                            {m.statut === 'annoncee' && <span class="ml-1 text-[11px] px-1.5 py-0.5 rounded" style="background:var(--bg-soft);color:var(--fg-muted)">Annonce</span>}
                                            {m.source_url && <a href={m.source_url} target="_blank" rel="nofollow noopener" class="text-brand-600 hover:underline ml-1">source ↗</a>}
                                        </li>
                                    ))}
                                </ul>
                                <p class="mt-2 text-xs" style="color: var(--fg-muted)">
                                    Propos relevés et vérifiés à la source — l'<strong>argumentaire pour/contre</strong> est en
                                    préparation avant publication complète (<a href="/methodologie/" class="text-brand-600 hover:underline">méthodologie</a>).
                                </p>
                            </>
                        )}
                        {etat === 'en_traitement' && (
                            <p class="mt-2 text-sm" style="color: var(--fg-muted)">
                                S'est exprimé sur ce thème ({info.nb_signaux} prise(s) de parole repérée(s)) — en cours de
                                vérification par notre équipe avant publication.
                                {info.source_url && <a href={info.source_url} target="_blank" rel="nofollow noopener" class="text-brand-600 hover:underline ml-1">source ↗</a>}
                            </p>
                        )}
                    </div>
                );
            })}

            {themesNonExprimes.length > 0 && (
                <details class="rounded-card border p-4" style="border-color: var(--border)">
                    <summary class="cursor-pointer text-sm font-medium" style="color: var(--fg-muted)">
                        Thèmes sans expression à ce jour ({themesNonExprimes.length})
                    </summary>
                    <p class="mt-2 text-sm flex flex-wrap gap-2">
                        {themesNonExprimes.map((t) => (
                            <span class="px-2 py-1 rounded-control text-xs" style="background: var(--bg-soft); color: var(--fg-muted)">{t.nom}</span>
                        ))}
                    </p>
                    <p class="mt-2 text-xs" style="color: var(--fg-muted)">Ne s'est pas exprimé publiquement sur ces thèmes, selon nos relevés.</p>
                </details>
            )}
        </div>
    </section>

    <!-- Prises de parole : citations vérifiables à la source (différenciateur) -->
    {prisesDeParole.length > 0 && (
        <section id="prises-de-parole" class="py-6">
            <h2 class="text-xl font-bold mb-1">Prises de parole</h2>
            <p class="text-sm mb-4" style="color: var(--fg-muted)">
                Propos repérés dans les meetings et interviews, en cours de traitement par notre équipe.
                <strong>Chaque citation est vérifiable à la source en un clic.</strong>
            </p>
            <div class="space-y-3">
                {prisesDeParole.map((doc: any, iDoc: number) => (
                    <details class="rounded-card border" style="border-color: var(--border)" open={prisesDeParole.length === 1 && iDoc === 0}>
                        <summary class="cursor-pointer p-4 flex items-center justify-between gap-2 flex-wrap">
                            <span class="font-semibold text-sm">{doc.titre}</span>
                            <span class="text-xs whitespace-nowrap" style="color: var(--fg-muted)">
                                {doc.type}{doc.date ? ` · ${doc.date}` : ''} · {doc.citations.length} citation(s)
                            </span>
                        </summary>
                        <div class="px-4 pb-4 space-y-3">
                            {doc.url && <a href={doc.url} target="_blank" rel="nofollow noopener" class="text-xs text-brand-600 hover:underline">Voir le document source ↗</a>}
                            {citationsParTheme(doc).map(([theme, citations]) => (
                                <details class="border-l-2 pl-3" style="border-color: var(--border)" open={doc.citations.length <= 8}>
                                    <summary class="cursor-pointer text-xs font-semibold uppercase tracking-wide py-1" style="color: var(--fg-muted)">
                                        {theme} ({citations.length})
                                    </summary>
                                    <ul class="space-y-3 mt-1">
                                        {citations.map((cit: any) => (
                                            <li class="text-sm">
                                                <p class="italic">« {cit.citation} »</p>
                                                {cit.resume && <p class="text-xs mt-1" style="color: var(--fg-muted)">{cit.resume}</p>}
                                                {cit.verifier_url && (
                                                    <a href={cit.verifier_url} target="_blank" rel="nofollow noopener"
                                                       class="tap inline-flex items-center mt-1 text-xs font-medium text-brand-600 hover:underline">
                                                        ▶ Vérifier{cit.timecode ? ` à ${cit.timecode}` : ' à la source'}
                                                    </a>
                                                )}
                                            </li>
                                        ))}
                                    </ul>
                                </details>
                            ))}
                        </div>
                    </details>
                ))}
            </div>
        </section>
    )}

    <!-- Parcours -->
    <section id="parcours" class="py-6">
        <h2 class="text-xl font-bold mb-3">Parcours</h2>
        {c.parcours?.length ? (
            <ol class="border-l-2 pl-4 space-y-4" style="border-color: var(--border)">
                {c.parcours.map((e: any) => (
                    <li>
                        <div class="text-sm font-medium">{e.titre}{e.organisation && <span style="color: var(--fg-muted)"> · {e.organisation}</span>}</div>
                        <div class="text-xs" style="color: var(--fg-muted)">
                            {e.date_debut ?? '?'}{e.date_fin ? ` — ${e.date_fin}` : ' — en cours'}
                            {e.source_url && <a href={e.source_url} target="_blank" rel="nofollow noopener" class="text-brand-600 hover:underline ml-1">source ↗</a>}
                        </div>
                        {e.actions?.length > 0 && (
                            <details class="mt-1">
                                <summary class="cursor-pointer text-xs font-medium text-brand-600">
                                    Actions durant cette fonction ({e.actions.length}) — données CivicDash
                                </summary>
                                <ul class="mt-2 space-y-1.5 text-xs" style="color: var(--fg-muted)">
                                    {e.actions.map((a: any) => (
                                        <li>
                                            <span class="font-mono">{a.date}</span> — {a.titre}
                                            {a.source_url && <a href={a.source_url} target="_blank" rel="nofollow noopener" class="text-brand-600 hover:underline ml-1">JO ↗</a>}
                                        </li>
                                    ))}
                                </ul>
                                <p class="text-[11px] mt-2" style="color: var(--fg-muted)">
                                    Sélection mécanique, sans choix éditorial : {e.actions[0].critere}
                                    (<a href="/methodologie/" class="text-brand-600 hover:underline">méthodologie</a>).
                                </p>
                            </details>
                        )}
                    </li>
                ))}
            </ol>
        ) : (
            <p class="text-sm" style="color: var(--fg-muted)">Parcours en cours de constitution (import Wikidata / HATVP).</p>
        )}
    </section>

    <!-- Affaires judiciaires : composant le plus sensible (présomption d'innocence) -->
    <section id="affaires" class="py-6">
        <h2 class="text-xl font-bold mb-3">Affaires judiciaires</h2>

        {c.affaires?.publiees?.length ? (
            <div class="space-y-4">
                {c.affaires.publiees.map((a: any) => (
                    <article class="rounded-card border overflow-hidden" style="border-color: var(--border)">
                        {a.presomption_innocence && (
                            <p class="text-sm px-4 py-3" style="background:#fffbeb; color:#92400e; border-bottom:1px solid var(--border)">
                                ⚠ Décision de justice non définitive. <strong>La présomption d'innocence s'applique.</strong>
                                {a.aucune_mise_en_examen && ' Aucune mise en examen n\'a été prononcée à ce jour.'}
                            </p>
                        )}
                        <div class="p-4">
                            <div class="flex items-center justify-between gap-2 mb-2">
                                <h3 class="font-semibold">{a.titre}</h3>
                                <span class="text-xs px-2 py-1 rounded-full whitespace-nowrap"
                                      style={a.statut_judiciaire === 'condamne_definitif' ? 'background:#fef2f2;color:#b91c1c' : 'background:#fffbeb;color:#b45309'}>
                                    {a.statut_label}
                                </span>
                            </div>
                            {a.autorite && <p class="text-xs mb-2" style="color: var(--fg-muted)">{a.autorite}</p>}
                            {a.description && <p class="text-sm">{a.description}</p>}
                            {a.qualifications?.length > 0 && (
                                <ul class="text-xs mt-2 list-disc pl-5" style="color: var(--fg-muted)">
                                    {a.qualifications.map((q: string) => <li>{q}</li>)}
                                </ul>
                            )}
                            {a.position_interesse && (
                                <p class="text-xs mt-2 italic" style="color: var(--fg-muted)">Position de l'intéressé : {a.position_interesse}</p>
                            )}
                            {a.sources?.length > 0 && (
                                <p class="text-xs mt-3" style="color: var(--fg-muted)">
                                    {a.sources.length} source(s) vérifiée(s) :
                                    {a.sources.map((s: any, i: number) => (
                                        <span> {i > 0 ? '· ' : ''}{s.url ? <a href={s.url} target="_blank" rel="nofollow noopener" class="text-brand-600 hover:underline">{s.media}</a> : s.media}{s.archive_url && <a href={s.archive_url} target="_blank" rel="nofollow noopener" class="text-brand-600 hover:underline"> (archive)</a>}</span>
                                    ))}
                                </p>
                            )}
                        </div>
                    </article>
                ))}
            </div>
        ) : c.affaires?.en_verification ? (
            <div class="rounded-card border p-4 text-sm" style="border-color:#f59e0b; background:#fffbeb; color:#92400e">
                Un signalement judiciaire concernant ce candidat est <strong>en cours de vérification</strong> par notre équipe.
                Il ne sera publié qu'une fois les sources vérifiées et archivées, avec présomption d'innocence.
            </div>
        ) : (
            <div class="rounded-card border p-4 text-sm" style="border-color: var(--border); color: var(--fg-muted)">
                Aucune affaire judiciaire recensée à ce jour dans notre base — dernière vérification :
                {c.affaires?.derniere_verification ?? META.genere_le}.
                Une absence d'information n'est pas une preuve d'absence d'affaire.
            </div>
        )}
    </section>

    <div class="py-4 flex flex-wrap gap-3">
        <a href="/comparateur/" class="tap inline-flex items-center rounded-control bg-brand-600 text-white text-sm font-medium px-4 py-2 hover:bg-brand-800">Comparer</a>
        <a href="/candidats/" class="tap inline-flex items-center rounded-control border text-sm px-4 py-2" style="border-color: var(--border)">← Tous les candidats</a>
    </div>
</Base>
