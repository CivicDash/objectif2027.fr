---
import Base from '@/layouts/Base.astro';
import CandidatCard from '@/components/CandidatCard.astro';
import { candidatsOrdreNeutre, THEMES } from '@/lib/data';
import { websiteJsonLd, organizationJsonLd } from '@/lib/seo';

const candidats = candidatsOrdreNeutre();
const nbPublies = candidats.filter((c) => c.couverture.themes_publies > 0).length;
const nbEnCours = candidats.filter((c) => c.couverture.themes_publies === 0 && c.couverture.themes_exprimes > 0).length;
---

<Base title="Objectif 2027 — l'élection présidentielle décryptée pour les citoyens"
      jsonld={[websiteJsonLd(), organizationJsonLd()]}>
    <section class="py-6">
        <p class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wide px-3 py-1 rounded-full"
           style="background: var(--bg-soft); color: var(--fg-muted)">Élection présidentielle française</p>
        <h1 class="mt-4 text-3xl md:text-5xl font-extrabold leading-tight tracking-tight">
            Comprendre les candidats et leurs programmes, <span class="text-brand-600">sans parti pris.</span>
        </h1>
        <p class="mt-4 text-lg max-w-2xl" style="color: var(--fg-muted)">
            Une application citoyenne, neutre et sourcée. Aucun compte, aucune publicité — les faits, leurs sources,
            et de quoi se faire son propre avis.
        </p>

        <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-xl">
            <div class="rounded-card border p-4" style="border-color: var(--border)">
                <div class="text-xs font-semibold uppercase text-brand-600">1<sup>er</sup> tour</div>
                <div class="text-lg font-bold">Dimanche 18 avril 2027</div>
            </div>
            <div class="rounded-card border p-4" style="border-color: var(--border)">
                <div class="text-xs font-semibold uppercase text-brand-600">2<sup>nd</sup> tour</div>
                <div class="text-lg font-bold">Dimanche 2 mai 2027</div>
            </div>
        </div>
        <p class="mt-2 text-xs" style="color: var(--fg-muted)">Dates annoncées, sous réserve du décret de convocation.</p>
    </section>

    <section class="py-6" aria-labelledby="candidats-titre">
        <div class="flex items-baseline justify-between">
            <h2 id="candidats-titre" class="text-xl font-bold">Les candidats</h2>
            <a href="/candidats/" class="text-sm text-brand-600 hover:underline">Tout voir →</a>
        </div>
        <p class="text-sm mt-1" style="color: var(--fg-muted)">Ordre alphabétique — traitement identique pour tous.</p>
        <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {candidats.map((c) => <CandidatCard candidat={c} />)}
        </div>
    </section>

    <section class="py-6 grid gap-4 md:grid-cols-2">
        <a href="/comparateur/" class="rounded-card border p-5 hover:border-brand-400" style="border-color: var(--border)">
            <h2 class="font-bold text-lg">Comparer les programmes</h2>
            <p class="text-sm mt-1" style="color: var(--fg-muted)">
                Thème par thème, jusqu'à 4 candidats côte à côte, avec arguments pour et contre sourcés.
            </p>
        </a>
        <a href="/demarche/" class="rounded-card border p-5 hover:border-brand-400" style="border-color: var(--border)">
            <h2 class="font-bold text-lg">Notre démarche</h2>
            <p class="text-sm mt-1" style="color: var(--fg-muted)">
                Neutralité, méthode publique, sources archivées, présomption d'innocence. Portée par l'association Civis-Consilium.
            </p>
        </a>
    </section>

    <section class="py-6" aria-labelledby="roadmap-titre">
        <div class="rounded-card border p-5" style="border-color: var(--border); background: var(--bg-soft)">
            <h2 id="roadmap-titre" class="text-lg font-bold">Où en est notre travail</h2>
            <p class="text-sm mt-1" style="color: var(--fg-muted)">
                Nous traitons les candidats un par un, à égalité, en vérifiant chaque source. La couverture est
                volontairement partielle et honnête : elle grandit à mesure des validations.
            </p>
            <ul class="mt-3 flex flex-wrap gap-4 text-sm">
                <li><strong>{candidats.length}</strong> candidats déjà en ligne</li>
                <li><strong>{nbPublies}</strong> avec des mesures publiées</li>
                <li><strong>{nbEnCours}</strong> en cours de traitement</li>
            </ul>
            <p class="text-xs mt-3" style="color: var(--fg-muted)">
                D'autres candidats déclarés sont en cours d'intégration (vérification des sources avant publication).
                Revenez régulièrement : le contenu s'enrichit au fil des vérifications.
            </p>
        </div>
    </section>

    <section class="py-6" aria-labelledby="themes-titre">
        <h2 id="themes-titre" class="text-xl font-bold">Les {THEMES.length} thèmes</h2>
        <div class="mt-3 flex flex-wrap gap-2">
            {THEMES.map((t) => (
                <a href={`/themes/${t.slug}/`} class="tap inline-flex items-center px-3 py-2 rounded-control border text-sm hover:border-brand-400" style="border-color: var(--border)">
                    {t.nom}
                </a>
            ))}
        </div>
    </section>
</Base>
