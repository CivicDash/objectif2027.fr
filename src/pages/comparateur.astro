---
import Base from '@/layouts/Base.astro';
import Comparateur from '@/islands/Comparateur.vue';
import { CANDIDATS_DETAIL, THEMES } from '@/lib/data';

// On ne transmet à l'island que le nécessaire (léger : peu de candidats).
const candidats = Object.values(CANDIDATS_DETAIL).map((c: any) => ({
    slug: c.slug,
    nom_complet: c.nom_complet,
    couleur_hex: c.couleur_hex,
    etats_par_theme: c.etats_par_theme,
    mesures_par_theme: c.mesures_par_theme,
    mesures_relevees_par_theme: c.mesures_relevees_par_theme,
}));
---

<Base title="Comparateur des programmes — Objectif 2027" description="Comparez côte à côte les programmes des candidats à la présidentielle 2027, thème par thème, avec arguments pour et contre sourcés.">
    <h1 class="text-2xl font-bold py-4">Comparateur</h1>
    <p class="text-sm mb-4" style="color: var(--fg-muted)">
        Sélectionnez 2 à 4 candidats et un thème. Le lien de la page encode votre sélection : partagez-le tel quel.
    </p>
    <Comparateur client:load candidats={candidats} themes={THEMES} />

    <noscript>
        <p class="mt-4 text-sm rounded-card border p-4" style="border-color: var(--border)">
            Le comparateur interactif nécessite JavaScript. Vous pouvez consulter chaque thème via la
            <a href="/" class="text-brand-600 hover:underline">page d'accueil</a> ou les fiches candidats.
        </p>
    </noscript>
</Base>
