---
import '@/styles/global.css';

export interface Props {
    title: string;
    description?: string;
    ogImage?: string;
    canonical?: string;
}

const {
    title,
    description = "Comprendre l'élection présidentielle française de 2027 : candidats, programmes, arguments sourcés. Application citoyenne, neutre, sans compte.",
    ogImage = '/og/default.png',
    canonical,
} = Astro.props;

const url = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const annee = 2027;
---

<!doctype html>
<html lang="fr">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={url} />
        <meta name="theme-color" content="#1e3a8a" />
        <meta name="robots" content="index, follow" />

        <meta property="og:type" content="website" />
        <meta property="og:locale" content="fr_FR" />
        <meta property="og:site_name" content="Objectif 2027" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={url} />
        <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
        <meta name="twitter:card" content="summary_large_image" />
    </head>
    <body class="min-h-dvh flex flex-col">
        <a href="#contenu" class="skip-link">Aller au contenu</a>

        <header class="border-b" style="border-color: var(--border)">
            <div class="mx-auto max-w-content px-4 h-14 flex items-center justify-between gap-6">
                <a href="/" class="font-bold tracking-tight text-lg shrink-0">Objectif&nbsp;{annee}</a>
                <!-- Navigation desktop uniquement (le mobile utilise la tab bar du bas) -->
                <nav aria-label="Navigation principale" class="hidden md:flex items-center gap-7 text-sm font-medium">
                    <a href="/candidats/" class="hover:text-brand-600">Candidats</a>
                    <a href="/comparateur/" class="hover:text-brand-600">Comparateur</a>
                    <a href="/quiz/" class="hover:text-brand-600">Quiz</a>
                    <a href="/themes/" class="hover:text-brand-600">Thèmes</a>
                    <a href="/demarche/" class="hover:text-brand-600">Démarche</a>
                    <a href="/recherche/" aria-label="Recherche" class="hover:text-brand-600 inline-flex items-center" title="Recherche">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
                    </a>
                </nav>
                <!-- Mobile : accès recherche dans la barre du haut (le reste est en tab bar) -->
                <a href="/recherche/" aria-label="Recherche" class="md:hidden inline-flex items-center justify-center tap">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
                </a>
            </div>
        </header>

        <main id="contenu" class="flex-1 w-full mx-auto max-w-content px-4 py-6 pb-24 md:pb-8">
            <slot />
        </main>

        <!-- Tab bar mobile fixe (navigation au pouce) — masquée en desktop -->
        <nav aria-label="Navigation mobile"
             class="md:hidden fixed bottom-0 inset-x-0 z-20 border-t flex"
             style="background: var(--bg); border-color: var(--border); padding-bottom: env(safe-area-inset-bottom)">
            <a href="/candidats/" class="flex-1 flex flex-col items-center gap-0.5 py-2 text-xs" style="min-height:56px">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg>
                Candidats
            </a>
            <a href="/comparateur/" class="flex-1 flex flex-col items-center gap-0.5 py-2 text-xs" style="min-height:56px">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M9 3v18M15 3v18M3 9h18M3 15h18"/></svg>
                Comparer
            </a>
            <a href="/quiz/" class="flex-1 flex flex-col items-center gap-0.5 py-2 text-xs" style="min-height:56px">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M9 9a3 3 0 1 1 4 2.8c-.8.4-1 .9-1 1.7M12 17h.01"/><circle cx="12" cy="12" r="9"/></svg>
                Quiz
            </a>
            <a href="/themes/" class="flex-1 flex flex-col items-center gap-0.5 py-2 text-xs" style="min-height:56px">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                Thèmes
            </a>
        </nav>

        <footer class="border-t text-sm" style="border-color: var(--border); color: var(--fg-muted)">
            <div class="mx-auto max-w-content px-4 py-8 space-y-2">
                <p>
                    Données : <strong>CivicDash</strong> / <strong>Civis-Consilium</strong> — sources vérifiées,
                    licence AGPL-3.0.
                </p>
                <p class="flex flex-wrap gap-x-4 gap-y-1">
                    <a href="/recherche/" class="hover:underline">Recherche</a>
                    <a href="/methodologie/" class="hover:underline">Méthodologie</a>
                    <a href="/mentions-legales/" class="hover:underline">Mentions légales</a>
                    <a href="/data/candidats.json" class="hover:underline">Données ouvertes</a>
                    <a href="https://civis-consilium.eu" class="hover:underline">À propos de l'association</a>
                    <a href="https://civicdash.fr" class="hover:underline">La plateforme CivicDash</a>
                    <a href="/signaler/" class="hover:underline">Signaler une erreur</a>
                </p>
            </div>
        </footer>
    </body>
</html>
